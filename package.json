{
  "name": "ecommerce-3d-mcp",
  "version": "2.1.0",
  "description": "MCP server for e-commerce 3D product visualization \u2014 model viewers, AR try-on, product configurators, Shopify/WooCommerce integration, conversion optimization, size guides",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "ecommerce-3d-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "3d",
    "ecommerce",
    "shopify",
    "woocommerce",
    "ar",
    "augmented-reality",
    "product-visualization",
    "model-viewer",
    "configurator",
    "webxr",
    "size-guide",
    "conversion-optimization",
    "schema-org"
  ],
  "author": "SceneView Tools",
  "license": "MIT",
  "homepage": "https://github.com/sceneview-tools/ecommerce-3d-mcp",
  "repository": {
    "type": "git",
    "url": "https://github.com/sceneview-tools/ecommerce-3d-mcp.git"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "server.json"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  },
  "mcpName": "io.github.sceneview-tools/ecommerce-3d-mcp",
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/sceneview"
    },
    {
      "type": "polar",
      "url": "https://polar.sh/sceneview"
    }
  ]
